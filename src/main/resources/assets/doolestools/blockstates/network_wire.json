{
  "multipart": [
    { "when": { "cable": "true" }, "apply": { "model": "doolestools:block/network_wire_core" } },
    { "when": { "cable": "true", "down": "true" }, "apply": { "model": "doolestools:block/network_wire_down" } },
    { "when": { "cable": "true", "up": "true" }, "apply": { "model": "doolestools:block/network_wire_up" } },
    { "when": { "cable": "true", "north": "true" }, "apply": { "model": "doolestools:block/network_wire_north" } },
    { "when": { "cable": "true", "south": "true" }, "apply": { "model": "doolestools:block/network_wire_south" } },
    { "when": { "cable": "true", "west": "true" }, "apply": { "model": "doolestools:block/network_wire_west" } },
    { "when": { "cable": "true", "east": "true" }, "apply": { "model": "doolestools:block/network_wire_east" } },
    { "when": { "endpoint_down": "true" }, "apply": { "model": "doolestools:block/network_wire_endpoint_down" } },
    { "when": { "endpoint_up": "true" }, "apply": { "model": "doolestools:block/network_wire_endpoint_up" } },
    { "when": { "endpoint_north": "true" }, "apply": { "model": "doolestools:block/network_wire_endpoint_north" } },
    { "when": { "endpoint_south": "true" }, "apply": { "model": "doolestools:block/network_wire_endpoint_south" } },
    { "when": { "endpoint_west": "true" }, "apply": { "model": "doolestools:block/network_wire_endpoint_west" } },
    { "when": { "endpoint_east": "true" }, "apply": { "model": "doolestools:block/network_wire_endpoint_east" } }
  ]
}
